{
    "name": "deskerp-desktop",
    "version": "0.1.0",
    "private": true,
    "description": "Electron wrapper for DeskERP",
    "main": "main.js",
    "scripts": {
        "dev": "cross-env DESKERP_START_URL=http://127.0.0.1:8000 DESKERP_SKIP_SERVER=1 electron .",
        "dev:managed": "electron .",
        "package:win": "electron-builder --win portable"
    },
    "devDependencies": {
        "cross-env": "^7.0.3",
        "electron": "^36.3.1",
        "electron-builder": "^24.13.3"
    },
    "build": {
        "appId": "local.deskerp.desktop",
        "productName": "DeskERP",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "package.json"
        ]
    }
}
